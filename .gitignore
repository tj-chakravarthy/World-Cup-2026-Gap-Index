# --- Secrets / environment ---
.env
.env.local

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
*.egg-info/

.DS_Store

# --- Data artifacts ---
# web/public/data/*.json is the deploy artifact and is NOT covered here — it stays tracked.
# raw + processed are large, regenerable caches → ignore the contents, keep the tree.
data/raw/**
data/processed/**
!data/raw/**/
!data/processed/**/
!**/.gitkeep
# the frozen pre-tournament model bundle (indices + production logistic + Dixon-Coles +
# bootstrap bags) is the ONE processed artifact the live cron can't regenerate: building it
# needs the raw scrape (FBref/Understat/match_results), which is ignored. So it's committed
# (3.9M) and loaded as-is on every run. Rebuild + recommit when the model code changes
# (BUNDLE_VERSION bump): a stale-version load would try to rebuild and fail in CI (no raw data).
!data/processed/model_bundle.pkl
# fixtures are a small canonical input (the lock's spine, a structured fixture feed),
# not bulk scrape → tracked, not ignored.
!data/raw/fixtures_2026.csv
# team-code crosswalk: small, canonical, hand-reviewed source-name -> FIFA map → tracked.
!data/raw/team_codes.csv
# transfermarkt national-team id crosswalk: small, hand-reviewable FIFA -> TM verein
# id map → tracked. The per-squad transfermarkt_{code}_{season}.csv values are bulk
# scrape (regenerable) → ignored.
!data/raw/transfermarkt_team_ids.csv
# squads: 48 final 26-man rosters, canonical tournament input → tracked.
!data/raw/squads_2026.csv
!data/raw/squads_2018.csv
!data/raw/squads_2022.csv
# name overrides: hand-curated, append-only manual name corrections → tracked.
!data/raw/name_overrides.csv
# market_odds: small (112K) Pinnacle closing-odds slices for the 4 backtest tournaments,
# the basis of the §4.6 market benchmark. Third-party (eatpizzanot/soccer-dataset,
# CC-BY-4.0) and could vanish, so committed for a reproducible benchmark, with attribution.
!data/raw/market_odds/
!data/raw/market_odds/*.csv
# FIFA ranking: the Art. 13 final group tiebreaker, fetched from inside.fifa.com
# (fetch_fifa_rankings) → tracked, real edition (not the Elo proxy). cards_2026.csv (the
# §1 f) conduct input) is allowlisted too for when card data is loaded.
!data/raw/fifa_rankings_2026.csv
!data/raw/cards_2026.csv
# Annex C third-place allocation: FIFA's exact 495-row table (fetch_annex_c), the
# bracket.py R32 third assignment → tracked (replaces the constraint-solver approximation).
!data/raw/annex_c_thirds.csv
# data/predictions/ is the committed record (locked file's verifiable git timestamp,
# append-only audit log, market benchmark) — no ignore rule, tracked normally.

# --- soccerdata / scraper caches ---
.soccerdata/

# --- Project docs kept private for now (un-ignore when ready to publish) ---
CLAUDE.md
PLAN.md

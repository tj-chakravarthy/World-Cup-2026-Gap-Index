# --- Secrets / environment ---
.env
.env.local

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
*.egg-info/

# --- Node / Next.js (web/) ---
node_modules/
web/.next/
web/out/
web/next-env.d.ts
.vercel/
.DS_Store

# --- Data artifacts ---
# web/public/data/*.json is the deploy artifact and is NOT covered here — it stays tracked.
# raw + processed are large, regenerable caches → ignore the contents, keep the tree.
data/raw/**
data/processed/**
!data/raw/**/
!data/processed/**/
!**/.gitkeep
# data/predictions/ is the committed record (locked file's verifiable git timestamp,
# append-only audit log, market benchmark) — no ignore rule, tracked normally.

# --- soccerdata / scraper caches ---
.soccerdata/

# --- Project docs kept private for now (un-ignore when ready to publish) ---
CLAUDE.md
PLAN.md

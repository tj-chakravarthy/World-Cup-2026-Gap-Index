# API-Football (api-football.com) — fixtures, lineups, injuries, odds capture.
# Free tier = 100 requests/day. Required.
API_FOOTBALL_KEY=

# The Odds API (the-odds-api.com) — fallback odds source (benchmark only). Optional.
ODDS_API_KEY=

# Kaggle — only needed to download the Elo history and martj42 results datasets
# via the Kaggle API. From kaggle.com/settings -> Create New Token.
KAGGLE_USERNAME=
KAGGLE_KEY=
